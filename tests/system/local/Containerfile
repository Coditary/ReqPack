FROM fedora:43

RUN dnf install -y \
        bash \
        ca-certificates \
        coreutils \
        grep \
        sed \
        tar \
        zstd \
    && dnf clean all

COPY rqp.tar.gz /tmp/rqp.tar.gz

RUN mkdir -p /opt/reqpack \
    && tar -xzf /tmp/rqp.tar.gz -C /opt/reqpack \
    && chmod +x /opt/reqpack/rqp /opt/reqpack/bin/rqp.bin \
    && ln -sf /opt/reqpack/rqp /usr/local/bin/rqp \
    && rm -f /tmp/rqp.tar.gz

WORKDIR /workspace
